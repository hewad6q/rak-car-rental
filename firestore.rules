rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { 
      return request.resource.data; 
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['name', 'phone', 'message', 'status'])
        && data.keys().size() <= 10
        && data.name is string && data.name.size() <= 200 && data.name.size() > 0
        && data.phone is string && data.phone.size() <= 50 && data.phone.size() > 0
        && data.message is string && data.message.size() <= 3000
        && data.status is string && (data.status == 'New' || data.status == 'Contacted' || data.status == 'Done');
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Secure Bookings Collection Match
    match /bookings/{bookingId} {
      allow create: if isValidId(bookingId) && isValidBooking(incoming());
      allow read: if true;
      allow update: if isValidId(bookingId) && isValidBooking(incoming());
      allow delete: if true;
    }
  }
}
