rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Cars Collection Rules
    match /cars/{carId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Bookings Collection Rules
    match /bookings/{bookingId} {
      allow read, write: if true;
    }
    
    // Customers Collection Rules
    match /customers/{customerId} {
      allow read, write: if true;
    }

    // Offers Collection Rules
    match /offers/{offerId} {
      allow read: if true;
      allow write: if true;
    }

    // Announcements Collection Rules
    match /announcements/{annId} {
      allow read: if true;
      allow write: if true;
    }

    // Reviews Collection Rules
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if true;
    }

    // FAQs Collection Rules
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if true;
    }

    // Settings Collection Rules
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if true;
    }

    // Analytics Collection Rules
    match /analytics/{analyticsId} {
      allow read, write: if true;
    }

    // Activity Log Collection Rules
    match /activity_log/{logId} {
      allow read, write: if true;
    }

    // Contact Inquiries (backup) Collection Rules
    match /contact_inquiries/{inqId} {
      allow read, write: if true;
    }

    // Database Connection Test Collection Rules
    match /test/{documentId} {
      allow read: if true;
    }
  }
}
